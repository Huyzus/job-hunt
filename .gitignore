# Personal data (user fills these)
cv.md
.superpowers/
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
archive/*
!archive/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (portals.yml is still user-managed)
portals.yml
.update-dismissed
.update-lock

# Interview prep is User Layer per DATA_CONTRACT (often symlinked to a personal vault)
interview-prep/story-bank.md
interview-prep/debriefs/*
!interview-prep/debriefs/.gitkeep

# Auto-generated weakness map (User Layer — regenerated by analyze-interview-patterns.mjs)
data/weakness-map.md

# Secrets (never commit — use .env.example as template)
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# Editor / tool backup files
*.bak
*.swp
.DS_Store

# macOS Finder / iCloud Drive sync conflict duplicates ("filename 2.ext")
# These appear when the same file is rapidly rewritten while iCloud Drive
# is syncing. Recommended: disable "Desktop & Documents in iCloud Drive"
# in System Settings → Apple Account → iCloud → iCloud Drive (or move this
# repo out of ~/Documents).
* 2.*
* 2.md
* 2.mjs
* 2.yml
* 2.yaml
* 2.json

